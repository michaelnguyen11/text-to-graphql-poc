# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here

# OpenAI models & Temperature
# Supervisor & Planner Model
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.1

# Embedding Model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG / Context Models (Can be different from Supervisor)
# Model for reformatting metadata during ingestion
INGEST_MODEL=gpt-4.1-mini
INGEST_TEMPERATURE=0.0

# Model for query rewriting/enhancement in retriever
RETRIEVAL_MODEL=gpt-4.1-mini
RETRIEVAL_TEMPERATURE=0.0

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
DATA_DIR=./data

# Observability Toggle (LangSmith or LangFuse)
LANGSMITH_ENABLED=true

# LangSmith / LangChain Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=tcb-text-to-graphql
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Amazon Bedrock (Enterprise Adaptation)
# Claude 4.6 Sonnet: anthropic.claude-4-6-sonnet-v1:0
# Claude 4.6 Opus: anthropic.claude-4-6-opus-v1:0
# Claude 4.5 Haiku: anthropic.claude-4-5-haiku-v1:0
AWS_REGION=ap-southeast-1

# Server
HOST=0.0.0.0
PORT=4444
LOG_LEVEL=info
